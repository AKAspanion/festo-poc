## PingOne OAuth Backend Configuration
## Copy this file to ".env" and fill in real values.

# PingOne Environment ID
PINGONE_ENV_ID=YOUR_ENVIRONMENT_ID

# PingOne OAuth Client ID
PINGONE_CLIENT_ID=YOUR_CLIENT_ID

# PingOne OAuth Client Secret (KEEP SECURE! BACKEND ONLY)
PINGONE_CLIENT_SECRET=YOUR_CLIENT_SECRET

# PingOne regional hosts (use the region for your tenant)
PINGONE_AUTH_URL=https://auth.pingone.com
PINGONE_API_URL=https://api.pingone.com

# Server port
PORT=3001

# Frontend origin(s) - adjust based on your Expo dev/prod URLs
FRONTEND_URL=http://localhost:19000

# Node environment
NODE_ENV=development

