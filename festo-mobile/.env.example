## PingOne OAuth Mobile Configuration
## Copy this file to ".env" and fill in real values.

# Must match PINGONE_ENV_ID in festo-backend/.env
EXPO_PUBLIC_PINGONE_ENV_ID=YOUR_ENVIRONMENT_ID

# PingOne OAuth Client ID (same as backend client ID)
EXPO_PUBLIC_PINGONE_CLIENT_ID=YOUR_CLIENT_ID

# Optional: override PingOne regional hosts (defaults are global)
# EXPO_PUBLIC_PINGONE_AUTH_URL=https://auth.pingone.com
# EXPO_PUBLIC_PINGONE_API_URL=https://api.pingone.com

# Backend server URL (where festo-backend is running)
EXPO_PUBLIC_BACKEND_URL=http://localhost:3001

